# Servidor
PORT=3000
NODE_ENV=development

# Supabase
# Encontre em: https://supabase.com/dashboard/project/<seu-projeto>/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Administrador
# Gere o hash com: node -e "const b=require('bcryptjs');b.hash('sua_senha',12).then(console.log)"
ADMIN_EMAIL=admin@suaclinica.com
ADMIN_PASSWORD_HASH=$2b$12$hash_gerado_pelo_bcrypt_aqui

# JWT
# Use uma string longa e aleatória. Ex: openssl rand -base64 48
JWT_SECRET=sua_chave_secreta_jwt_muito_longa_e_aleatoria

# CORS — URL do seu front-end
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5173/seu-caminho-admin
